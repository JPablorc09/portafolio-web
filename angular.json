{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "ed39e2e0-23fd-44b8-a9da-4e0071d28043"
  },
  "newProjectRoot": "projects",
  "projects": {
    "portafolio-web": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
      "options": {
  "outputPath": "dist/portafolio-web",
  "browser": "src/main.ts",
  "server": "src/main.server.ts",
  "tsConfig": "tsconfig.app.json",
  "outputMode": "server",
  "ssr": {
    "entry": "src/server.ts"
  },
  "assets": [
    {
      "glob": "**/*",
      "input": "public"
    },
    {
      "glob": "**/*",
      "input": "src/assets",
      "output": "assets"
    }
  ],
  "styles": [
    "src/styles.css"
  ],
  "security": {
    "allowedHosts": []
  }
},
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "750kB",
                  "maximumError": "1.5MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "14kB",
                  "maximumError": "20kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "portafolio-web:build:production"
            },
            "development": {
              "buildTarget": "portafolio-web:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}